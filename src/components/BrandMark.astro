---
/**
 * BrandMark — three rice grains arranged in a triangle.
 * Koji (Aspergillus oryzae) is the fungus cultivated on steamed rice
 * to produce miso, sake, soy sauce, and mirin. The mark nods to that.
 *
 * The top grain is the accent color (vermillion), the bottom two use the
 * body color. Both are configurable via props so the mark adapts to
 * dark/light contexts.
 */

interface Props {
  size?: number;
  color?: string;
  accent?: string;
  class?: string;
}

const {
  size = 32,
  color = 'currentColor',
  accent = 'var(--vermillion)',
  class: className = '',
} = Astro.props;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 128 128"
  width={size}
  height={size}
  class={className}
  aria-hidden="true"
>
  <ellipse cx="40" cy="84" rx="12" ry="25" transform="rotate(-22 40 84)" fill={color} />
  <ellipse cx="88" cy="84" rx="12" ry="25" transform="rotate(22 88 84)" fill={color} />
  <ellipse cx="64" cy="42" rx="12" ry="25" fill={accent} />
</svg>
