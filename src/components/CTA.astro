---
---

<section class="cta">
  <div class="container">
    <div class="cta-head">
      <p class="eyebrow">
        <span>Two ways to start today</span>
      </p>

      <h2 class="display">
        Try Koji<br/>
        <em class="italic">on something real.</em>
      </h2>

      <p class="lede">
        Point it at an invoice, a contract, a form — anything you've been meaning to turn into data. Start in the cloud if you want speed, or install the open source core if you want control.
      </p>
    </div>

    <div class="cta-paths">
      <div class="cta-path">
        <div class="path-label">
          <span class="label-num">01</span>
          <span class="label-name">Koji Cloud</span>
        </div>
        <h3 class="display path-title">Sign up, upload, done.</h3>
        <p class="path-desc">
          Two minutes from zero to your first extraction. 100 docs/month free forever, $49/month Pro with 500 docs included. Launching soon.
        </p>
        <a href="/waitlist" class="btn btn-primary">
          Request early access
          <span class="arrow">→</span>
        </a>
      </div>

      <div class="cta-divider" aria-hidden="true"></div>

      <div class="cta-path">
        <div class="path-label">
          <span class="label-num">02</span>
          <span class="label-name">Koji OSS</span>
        </div>
        <h3 class="display path-title">pip install, go.</h3>
        <p class="path-desc">
          Apache 2.0 licensed. Full product, no feature gates. Runs on Docker, docker-compose, or Kubernetes. Your infrastructure, your rules.
        </p>
        <div class="install-block">
          <div class="install-header">
            <span class="install-label">Install</span>
            <button class="copy-btn" type="button" data-copy="pip install koji-cli" aria-label="Copy command">
              <span>copy</span>
            </button>
          </div>
          <pre class="install-cmd"><span class="tok-prompt">$</span> pip install koji-cli</pre>
        </div>
        <a href="https://github.com/getkoji/koji" class="path-github">
          View on GitHub →
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .cta {
    padding: var(--section-pad) 0;
    background: var(--cream-2);
    border-top: 1px solid var(--border);
    position: relative;
    overflow: hidden;
  }

  .cta::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(to right, var(--border) 1px, transparent 1px);
    background-size: 64px 100%;
    opacity: 0.4;
    pointer-events: none;
  }

  .cta > * { position: relative; }

  .cta-head {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-bottom: 5rem;
    max-width: 720px;
  }

  .cta h2 {
    letter-spacing: -0.03em;
  }

  .cta .italic {
    color: var(--vermillion);
    font-style: italic;
    font-variation-settings: 'opsz' 144, 'SOFT' 100;
  }

  .cta .lede {
    max-width: 55ch;
  }

  /* Two-path grid ======================================================= */

  .cta-paths {
    display: grid;
    grid-template-columns: 1fr 1px 1fr;
    gap: 3rem;
    align-items: start;
  }

  .cta-path {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .path-label {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border);
  }

  .label-num {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.1rem;
    color: var(--vermillion);
    font-variation-settings: 'opsz' 12;
  }

  .label-name {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-3);
  }

  .path-title {
    font-size: clamp(1.7rem, 2.5vw, 2.1rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    font-weight: 400;
  }

  .path-desc {
    font-size: 0.98rem;
    line-height: 1.6;
    color: var(--ink-2);
    max-width: 44ch;
    margin-bottom: 0.5rem;
  }

  .cta-divider {
    background: var(--border);
    align-self: stretch;
  }

  .path-github {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--ink);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 4px;
    transition: color 0.3s;
  }

  .path-github:hover {
    color: var(--vermillion);
  }

  .cta-path .btn {
    align-self: flex-start;
  }

  .install-block {
    background: var(--ink);
    color: var(--cream-2);
    border-radius: 3px;
    overflow: hidden;
    box-shadow: var(--shadow-lg);
  }

  .install-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 1rem 0.75rem 1.25rem;
    border-bottom: 1px solid rgba(244, 238, 226, 0.08);
  }

  .install-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--cream-4);
  }

  .copy-btn {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--cream-3);
    padding: 0.3rem 0.65rem;
    border: 1px solid rgba(244, 238, 226, 0.15);
    border-radius: 2px;
    transition: all 0.3s;
  }

  .copy-btn:hover {
    color: var(--cream);
    border-color: var(--vermillion);
    background: var(--vermillion);
  }

  .copy-btn.copied {
    background: var(--vermillion);
    color: var(--cream);
    border-color: var(--vermillion);
  }

  .install-cmd {
    font-family: var(--font-mono);
    font-size: 1rem;
    padding: 1.4rem 1.25rem;
    margin: 0;
    color: var(--cream);
    letter-spacing: -0.01em;
  }

  @media (max-width: 900px) {
    .cta-paths {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .cta-divider {
      display: none;
    }
  }

  @media (max-width: 560px) {
    .cta-path .btn {
      justify-content: center;
      align-self: stretch;
    }
  }
</style>

<script>
  const copyBtn = document.querySelector<HTMLButtonElement>('.copy-btn');
  if (copyBtn) {
    copyBtn.addEventListener('click', async () => {
      const text = copyBtn.dataset.copy ?? '';
      try {
        await navigator.clipboard.writeText(text);
        copyBtn.classList.add('copied');
        const label = copyBtn.querySelector('span');
        const original = label?.textContent ?? 'copy';
        if (label) label.textContent = 'copied';
        setTimeout(() => {
          copyBtn.classList.remove('copied');
          if (label) label.textContent = original;
        }, 1600);
      } catch {
        /* clipboard unavailable — ignore */
      }
    });
  }
</script>
