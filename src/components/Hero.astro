---
import BrandMark from './BrandMark.astro';
---

<section class="hero">
  <div class="container">
    <div class="hero-content">
      <p class="eyebrow reveal d1">
        <span>Open source</span>
        <span class="dot">·</span>
        <span>Cloud or self-hosted</span>
        <span class="dot">·</span>
        <span>Config-driven</span>
      </p>

      <h1 class="display reveal d2">
        Documents in.<br/>
        <span class="accent">Structured data</span> out.
      </h1>

      <p class="lede reveal d3">
        Koji turns any document — PDFs, Word, scans, contracts, forms — into clean, structured JSON. Run it on our cloud in two minutes, or self-host the open source core on your own infrastructure. Same product, your call.
      </p>

      <div class="hero-cta reveal d4">
        <a href="https://console.getkoji.dev/waitlist" class="btn btn-primary">
          Request cloud early access
          <span class="arrow">→</span>
        </a>
        <a href="#run" class="btn btn-ghost">
          Self-host today
        </a>
      </div>

      <div class="hero-snippet reveal d5">
        <div class="snippet-dots" aria-hidden="true">
          <span></span><span></span><span></span>
        </div>
        <div class="snippet-label" aria-hidden="true">self-hosted install</div>
        <pre class="code"><code><span class="tok-prompt">$</span> pip install koji-cli
<span class="tok-prompt">$</span> koji init myproject --template invoice
<span class="tok-prompt">$</span> koji process invoice.pdf
<span class="tok-out">→ output/invoice.json  (97% confidence, 2.4s)</span></code></pre>
      </div>
    </div>

    <div class="hero-mark reveal d6" aria-hidden="true">
      <BrandMark size={360} strokeWidth={2} />
    </div>
  </div>

  <div class="hero-scroll" aria-hidden="true">
    <span class="scroll-label">scroll</span>
    <span class="scroll-line"></span>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    padding: 10rem 0 6rem;
    overflow: hidden;
  }

  .hero .container {
    position: relative;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    gap: 2rem;
    padding-top: 2rem;
  }

  .hero-content .lede {
    max-width: 58ch;
  }

  .eyebrow .dot {
    color: var(--cream-4);
  }

  h1.display {
    margin-top: 0.5rem;
  }

  .display .accent {
    color: var(--vermillion);
    font-style: italic;
    font-variation-settings: 'opsz' 144, 'SOFT' 100;
  }

  .hero-cta {
    display: flex;
    gap: 0.85rem;
    flex-wrap: wrap;
    margin-top: 0.75rem;
  }

  /* Brand mark — large, quiet, positioned in the negative space.
     Rice grains are filled shapes so they need much lower opacity than the
     old stroke mark. Custom keyframe because the global fadeIn ends at 1. */

  @keyframes heroMarkFadeIn {
    from { opacity: 0; }
    to   { opacity: 0.12; }
  }

  .hero-mark {
    position: absolute;
    top: -60px;
    right: -90px;
    z-index: 0;
    opacity: 0.12;
    pointer-events: none;
    animation: heroMarkFadeIn 1.8s var(--ease-out) 0.3s both;
  }

  /* Snippet =============================================================== */

  .hero-snippet {
    margin-top: 1.75rem;
    background: var(--ink);
    border-radius: 4px;
    max-width: 640px;
    box-shadow:
      var(--shadow-lg),
      0 0 0 1px rgba(23, 20, 16, 0.04);
    position: relative;
    overflow: hidden;
  }

  .hero-snippet::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 34px;
    background: linear-gradient(180deg, rgba(255,255,255,0.02) 0%, transparent 100%);
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  .snippet-dots {
    position: absolute;
    top: 12px;
    left: 14px;
    display: flex;
    gap: 6px;
    z-index: 2;
  }

  .snippet-label {
    position: absolute;
    top: 12px;
    right: 16px;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(244, 238, 226, 0.45);
    z-index: 2;
  }

  .snippet-dots span {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.12);
  }

  .snippet-dots span:nth-child(1) { background: rgba(195, 53, 32, 0.55); }
  .snippet-dots span:nth-child(2) { background: rgba(232, 197, 131, 0.55); }
  .snippet-dots span:nth-child(3) { background: rgba(200, 215, 157, 0.55); }

  .hero-snippet pre {
    padding: 3rem 1.75rem 1.5rem;
    color: var(--cream-2);
    font-size: 0.82rem;
    line-height: 1.9;
    margin: 0;
    overflow-x: auto;
  }

  /* Scroll indicator ====================================================== */

  .hero-scroll {
    position: absolute;
    bottom: 2.5rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    z-index: 2;
    opacity: 0.45;
    animation: fadeIn 1s var(--ease-out) 1.5s both;
  }

  .scroll-label {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--ink-2);
  }

  .scroll-line {
    width: 1px;
    height: 36px;
    background: linear-gradient(to bottom, var(--ink-2), transparent);
    position: relative;
  }

  .scroll-line::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 12px;
    background: var(--vermillion);
    animation: scrollDrip 2.4s var(--ease-in-out) infinite;
  }

  @keyframes scrollDrip {
    0%, 100% { transform: translateY(-12px); opacity: 0; }
    40%      { transform: translateY(12px);  opacity: 1; }
    80%      { transform: translateY(36px);  opacity: 0; }
  }

  /* Responsive ============================================================ */

  @media (max-width: 960px) {
    .hero-mark {
      top: -40px;
      right: -120px;
      opacity: 0.04;
    }

    .hero-mark svg {
      width: 280px;
      height: 280px;
    }
  }

  @media (max-width: 680px) {
    .hero {
      padding: 8rem 0 5rem;
      min-height: auto;
    }

    .hero-mark {
      display: none;
    }

    .hero-cta {
      flex-direction: column;
      align-items: stretch;
    }

    .btn {
      justify-content: center;
    }

    .hero-scroll {
      display: none;
    }
  }
</style>
