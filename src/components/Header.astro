---
import BrandMark from './BrandMark.astro';

/**
 * Fetch the live GitHub star count at build time and bake it into the HTML.
 * No API key needed — public repos are unauthenticated (60 req/hr per IP,
 * plenty for Cloudflare Pages builds). If the fetch fails (rate limit,
 * network issue, repo not public yet), we render the Star button without
 * a count rather than showing a stale or fake number.
 */
let stars: number | null = null;
try {
  const res = await fetch('https://api.github.com/repos/getkoji/koji', {
    headers: { 'User-Agent': 'getkoji-website-build' },
  });
  if (res.ok) {
    const data = await res.json();
    if (typeof data.stargazers_count === 'number') {
      stars = data.stargazers_count;
    }
  }
} catch {
  // Swallow — fall through to null. The button still links to GitHub.
}

const formatStars = (n: number): string => {
  if (n >= 10000) return Math.round(n / 1000) + 'k';
  if (n >= 1000) return (n / 1000).toFixed(1) + 'k';
  return n.toString();
};
---

<header class="site-header">
  <div class="container">
    <nav class="nav">
      <a href="/" class="brand" aria-label="Koji home">
        <BrandMark size={34} strokeWidth={5} class="brand-svg" />
        <span class="brand-name">koji</span>
      </a>

      <ul class="nav-links">
        <li><a href="/#how">How it works</a></li>
        <li><a href="/#run">Cloud or self-hosted</a></li>
        <li><a href="/benchmarks">Benchmarks</a></li>
        <li><a href="/#pricing">Pricing</a></li>
        <li><a href="https://docs.getkoji.dev">Docs</a></li>
        <li><a href="https://github.com/getkoji/koji">GitHub</a></li>
      </ul>

      <a href="https://github.com/getkoji/koji" class="nav-cta">
        <span>★ Star</span>
        {stars !== null && stars > 0 && (
          <>
            <span class="cta-divider"></span>
            <span class="cta-count">{formatStars(stars)}</span>
          </>
        )}
      </a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    padding: 1.6rem 0;
    z-index: 10;
  }

  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    color: var(--ink);
  }

  .brand :global(.brand-svg) {
    transition: transform 0.6s var(--ease-out);
  }

  .brand:hover :global(.brand-svg) {
    transform: rotate(-6deg);
  }

  .brand-name {
    font-family: var(--font-display);
    font-size: 1.85rem;
    font-weight: 500;
    letter-spacing: -0.015em;
    font-variation-settings: 'opsz' 144, 'SOFT' 30;
    line-height: 1;
  }

  .nav-links {
    display: flex;
    list-style: none;
    gap: 2.25rem;
    font-size: 0.92rem;
    color: var(--ink-2);
  }

  .nav-links a {
    position: relative;
    transition: color 0.3s;
  }

  .nav-links a:hover {
    color: var(--vermillion);
  }

  .nav-links a::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -4px;
    height: 1px;
    background: var(--vermillion);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s var(--ease-out);
  }

  .nav-links a:hover::after {
    transform: scaleX(1);
  }

  .nav-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.5rem 0.85rem;
    border: 1px solid var(--border-strong);
    border-radius: 2px;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--ink);
    background: var(--cream);
    transition: all 0.3s;
  }

  .nav-cta:hover {
    background: var(--ink);
    color: var(--cream);
    border-color: var(--ink);
  }

  .cta-divider {
    width: 1px;
    height: 0.9rem;
    background: currentColor;
    opacity: 0.3;
  }

  .cta-count {
    color: var(--vermillion);
  }

  .nav-cta:hover .cta-count {
    color: var(--cream);
  }

  @media (max-width: 780px) {
    .nav-links {
      display: none;
    }
  }
</style>
