---
import BrandMark from './BrandMark.astro';

const rows = [
  { feature: 'Open source core',               kojiCloud: true,  kojiOss: true,  llama: false,     textract: false,     unstruct: 'Partial' },
  { feature: 'Self-hostable',                  kojiCloud: true,  kojiOss: true,  llama: false,     textract: false,     unstruct: 'Enterprise only' },
  { feature: 'Data stays in your network',     kojiCloud: 'Optional', kojiOss: true, llama: false, textract: false,     unstruct: 'Enterprise only' },
  { feature: 'BYO model provider',             kojiCloud: true,  kojiOss: true,  llama: false,     textract: false,     unstruct: false },
  { feature: 'Config-driven pipelines',        kojiCloud: true,  kojiOss: true,  llama: 'Partial', textract: false,     unstruct: 'Partial' },
  { feature: 'Per-field confidence',           kojiCloud: true,  kojiOss: true,  llama: false,     textract: 'Partial', unstruct: false },
  { feature: 'Predictable pricing',            kojiCloud: true,  kojiOss: true,  llama: false,     textract: true,      unstruct: false },
  { feature: 'Managed by us',                  kojiCloud: true,  kojiOss: false, llama: true,      textract: true,      unstruct: 'Enterprise only' },
  { feature: 'Free forever option',            kojiCloud: true,  kojiOss: true,  llama: false,     textract: false,     unstruct: false },
];

const renderCell = (value: any) => {
  if (value === true)  return { text: '✓', class: 'yes' };
  if (value === false) return { text: '—', class: 'no' };
  return { text: value, class: 'partial' };
};
---

<section class="compare" id="compare">
  <div class="container">
    <div class="label-row">
      <p class="section-label">
        <span class="num">07</span>
        <span>How it compares</span>
      </p>
      <hr class="rule flex-1" />
    </div>

    <div class="compare-head">
      <h2 class="display">
        The only platform<br/>
        built around your data.
      </h2>
    </div>

    <div class="table-wrap">
      <table class="compare-table">
        <thead>
          <tr>
            <th scope="col"></th>
            <th scope="col" class="col-us">
              <span class="brand-cell">
                <BrandMark size={20} strokeWidth={5} />
                <span>Koji Cloud</span>
              </span>
            </th>
            <th scope="col" class="col-us">
              <span class="brand-cell">
                <BrandMark size={20} strokeWidth={5} />
                <span>Koji OSS</span>
              </span>
            </th>
            <th scope="col">LlamaCloud</th>
            <th scope="col">AWS Textract</th>
            <th scope="col">Unstructured</th>
          </tr>
        </thead>
        <tbody>
          {rows.map((row) => (
            <tr>
              <th scope="row">{row.feature}</th>
              {(['kojiCloud', 'kojiOss', 'llama', 'textract', 'unstruct'] as const).map((key) => {
                const cell = renderCell(row[key]);
                const isUs = key === 'kojiCloud' || key === 'kojiOss';
                return <td class={`cell ${cell.class} ${isUs ? 'col-us' : ''}`}>{cell.text}</td>;
              })}
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <p class="footnote">
      Competitive data compiled from public documentation as of 2026. Something missing or inaccurate? <a href="https://github.com/getkoji/koji/issues">Open an issue.</a>
    </p>
  </div>
</section>

<style>
  .compare {
    padding: var(--section-pad) 0;
  }

  .label-row {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 4rem;
  }

  .flex-1 { flex: 1; }

  .compare-head {
    margin-bottom: 4rem;
  }

  .compare-head h2 {
    letter-spacing: -0.03em;
  }

  .table-wrap {
    overflow-x: auto;
    border: 1px solid var(--border);
    background: var(--cream);
    border-radius: 2px;
    box-shadow: var(--shadow-md);
  }

  .compare-table {
    width: 100%;
    border-collapse: collapse;
    font-family: var(--font-body);
    font-size: 0.95rem;
    min-width: 680px;
  }

  .compare-table thead tr {
    border-bottom: 1px solid var(--border-strong);
  }

  .compare-table th,
  .compare-table td {
    padding: 1.1rem 1.35rem;
    text-align: left;
    vertical-align: middle;
  }

  .compare-table thead th {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-3);
    padding-top: 1.5rem;
    padding-bottom: 1.5rem;
  }

  .compare-table thead th.col-us {
    color: var(--vermillion);
  }

  .brand-cell {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    text-transform: none;
    font-size: 1.05rem;
    font-family: var(--font-display);
    font-variation-settings: 'opsz' 144, 'SOFT' 30;
    letter-spacing: -0.005em;
  }

  .compare-table tbody tr {
    border-bottom: 1px solid var(--border);
    transition: background 0.3s;
  }

  .compare-table tbody tr:last-child {
    border-bottom: none;
  }

  .compare-table tbody tr:hover {
    background: var(--cream-2);
  }

  .compare-table tbody th {
    font-weight: 500;
    color: var(--ink);
    font-family: var(--font-body);
  }

  .cell {
    font-family: var(--font-mono);
    font-size: 0.85rem;
  }

  .cell.yes {
    color: var(--vermillion);
    font-weight: 500;
    font-size: 1.05rem;
  }

  .cell.no {
    color: var(--ink-4);
    font-size: 1.1rem;
  }

  .cell.partial {
    color: var(--ochre);
    font-style: italic;
  }

  .col-us {
    background: var(--vermillion-3);
    position: relative;
  }

  .compare-table tbody tr:hover .col-us {
    background: var(--vermillion-3);
    filter: brightness(0.98);
  }

  .footnote {
    margin-top: 1.25rem;
    font-size: 0.82rem;
    color: var(--ink-3);
  }

  .footnote a {
    color: var(--vermillion);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }
</style>
