---
import Layout from '../layouts/Layout.astro';
import BrandMark from '../components/BrandMark.astro';
import Waitlist from '../components/Waitlist.astro';
---

<Layout
  title="Get early access — Koji Cloud"
  description="Join the Koji Cloud waitlist. Be the first to process documents on the managed platform when it launches."
>
  <div class="page">
    <header class="mini-header">
      <div class="container">
        <a href="/" class="brand" aria-label="Koji home">
          <BrandMark size={34} strokeWidth={5} />
          <span class="brand-name">koji</span>
        </a>

        <a href="/" class="back-link">
          <span class="arrow" aria-hidden="true">←</span>
          <span>Back to home</span>
        </a>
      </div>
    </header>

    <main class="waitlist-page">
      <div class="container">
        <div class="waitlist-content">
          <p class="eyebrow reveal d1">
            <span>Koji Cloud · Launching in weeks</span>
          </p>

          <h1 class="display reveal d2">
            Get early access<br/>
            to <em class="accent">Koji Cloud</em>.
          </h1>

          <p class="lede reveal d3">
            The managed version of Koji opens soon. Join the waitlist and we'll email you the moment it's live — with a founding-user discount on your first three months of Pro.
          </p>

          <div class="form-block reveal d4">
            <Waitlist placeholder="you@company.com" buttonLabel="Request early access" />
          </div>

          <div class="whats-next reveal d5">
            <h2 class="next-title">What happens next</h2>
            <ol class="next-list">
              <li>
                <span class="step-num">01</span>
                <div class="step-body">
                  <strong>You join the list.</strong> We'll send a one-line confirmation email. That's it — no welcome sequence, no onboarding drip.
                </div>
              </li>
              <li>
                <span class="step-num">02</span>
                <div class="step-body">
                  <strong>We build the cloud.</strong> Same core as the open source version, hosted on Cloudflare. Same dashboard, same schemas, same extraction pipeline.
                </div>
              </li>
              <li>
                <span class="step-num">03</span>
                <div class="step-body">
                  <strong>We email you when it's live.</strong> Your invite comes with a founding-user code for 50% off Pro for three months.
                </div>
              </li>
            </ol>
          </div>

          <div class="alt-path reveal d6">
            <hr class="divider" />
            <p class="alt-lead">Don't want to wait?</p>
            <p class="alt-body">
              Koji OSS is available today — Apache 2.0 licensed, runs on your own infrastructure, free forever. It's the same product without the managed hosting.
            </p>
            <div class="alt-actions">
              <a href="https://github.com/getkoji/koji" class="alt-btn">
                View on GitHub
                <span class="arrow">→</span>
              </a>
              <a href="https://docs.getkoji.dev/getting-started/" class="alt-btn alt-btn-ghost">
                Install with pip
              </a>
            </div>
          </div>
        </div>
      </div>
    </main>

    <footer class="mini-footer">
      <div class="container">
        <p>© {new Date().getFullYear()} Koji contributors. Apache 2.0.</p>
        <nav>
          <a href="/">Home</a>
          <a href="https://github.com/getkoji/koji">GitHub</a>
          <a href="https://docs.getkoji.dev">Docs</a>
        </nav>
      </div>
    </footer>
  </div>
</Layout>

<style>
  .page {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  /* Mini header =========================================================== */

  .mini-header {
    padding: 1.6rem 0;
  }

  .mini-header .container {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    color: var(--ink);
  }

  .brand-name {
    font-family: var(--font-display);
    font-size: 1.85rem;
    font-weight: 500;
    letter-spacing: -0.015em;
    font-variation-settings: 'opsz' 144, 'SOFT' 30;
    line-height: 1;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    color: var(--ink-3);
    transition: color 0.3s;
  }

  .back-link:hover {
    color: var(--vermillion);
  }

  .back-link .arrow {
    transition: transform 0.3s var(--ease-out);
  }

  .back-link:hover .arrow {
    transform: translateX(-3px);
  }

  /* Main content ========================================================== */

  .waitlist-page {
    flex: 1;
    padding: clamp(3rem, 6vw, 6rem) 0 clamp(4rem, 8vw, 8rem);
  }

  .waitlist-content {
    max-width: 680px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .waitlist-content h1 {
    font-size: clamp(2.5rem, 6.5vw, 4.5rem);
    line-height: 1.02;
    letter-spacing: -0.03em;
  }

  .accent {
    color: var(--vermillion);
    font-style: italic;
    font-variation-settings: 'opsz' 144, 'SOFT' 100;
  }

  .lede {
    font-size: 1.2rem;
    line-height: 1.55;
    color: var(--ink-2);
    max-width: 56ch;
  }

  /* Form block ============================================================ */

  .form-block {
    margin-top: 0.75rem;
    padding: 2rem;
    background: var(--cream-2);
    border: 1px solid var(--border);
    border-radius: 3px;
  }

  /* What's next =========================================================== */

  .whats-next {
    margin-top: 3rem;
    padding-top: 3rem;
    border-top: 1px solid var(--border);
  }

  .next-title {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-3);
    margin-bottom: 2rem;
  }

  .next-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .next-list li {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1.25rem;
    align-items: baseline;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border);
  }

  .next-list li:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .step-num {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.3rem;
    color: var(--vermillion);
    font-variation-settings: 'opsz' 12, 'SOFT' 50;
    line-height: 1;
  }

  .step-body {
    font-size: 1rem;
    line-height: 1.55;
    color: var(--ink-2);
    max-width: 54ch;
  }

  .step-body strong {
    color: var(--ink);
    font-weight: 500;
  }

  /* Alt path ============================================================== */

  .alt-path {
    margin-top: 3rem;
    padding: 2.5rem;
    background: var(--cream-2);
    border: 1px solid var(--border);
    border-radius: 3px;
    position: relative;
  }

  .divider {
    display: none;
  }

  .alt-lead {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.3rem;
    color: var(--ink);
    margin-bottom: 0.5rem;
    font-variation-settings: 'opsz' 24, 'SOFT' 80;
  }

  .alt-body {
    font-size: 0.98rem;
    line-height: 1.55;
    color: var(--ink-2);
    max-width: 56ch;
    margin-bottom: 1.5rem;
  }

  .alt-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .alt-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.8rem 1.25rem;
    background: var(--ink);
    color: var(--cream);
    border: 1px solid var(--ink);
    border-radius: 2px;
    font-family: var(--font-body);
    font-size: 0.92rem;
    font-weight: 500;
    transition: all 0.3s;
  }

  .alt-btn:hover {
    background: var(--vermillion);
    border-color: var(--vermillion);
  }

  .alt-btn-ghost {
    background: transparent;
    color: var(--ink);
    border-color: var(--border-strong);
  }

  .alt-btn-ghost:hover {
    background: var(--ink);
    color: var(--cream);
    border-color: var(--ink);
  }

  .alt-btn .arrow {
    transition: transform 0.3s var(--ease-out);
  }

  .alt-btn:hover .arrow {
    transform: translateX(3px);
  }

  /* Mini footer =========================================================== */

  .mini-footer {
    padding: 2.5rem 0;
    border-top: 1px solid var(--border);
    margin-top: auto;
    font-size: 0.85rem;
    color: var(--ink-3);
  }

  .mini-footer .container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
  }

  .mini-footer nav {
    display: flex;
    gap: 1.75rem;
  }

  .mini-footer nav a {
    color: var(--ink-3);
    transition: color 0.3s;
  }

  .mini-footer nav a:hover {
    color: var(--vermillion);
  }

  /* Responsive ============================================================ */

  @media (max-width: 560px) {
    .mini-header .container {
      gap: 1rem;
    }

    .form-block {
      padding: 1.5rem;
    }

    .alt-path {
      padding: 1.75rem;
    }

    .alt-actions {
      flex-direction: column;
    }

    .alt-btn {
      justify-content: center;
    }

    .mini-footer .container {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
  }
</style>
