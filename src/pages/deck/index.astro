---
/**
 * Sales Deck — multi-page enterprise sales document.
 * Pattern follows /brief but is longer (13 slides + appendix).
 * Prints to PDF via browser print dialog.
 * Shareable URL the CRO sends to prospects.
 */
import BrandMark from '../../components/BrandMark.astro';
import '../../styles/global.css';

const benchmarks = [
  { category: 'SEC Filings · IRS Forms · Multi-Format', docs: 124,  fields: '577/577',     accuracy: '100.0%', highlight: true },
  { category: 'Insurance Certificates', docs: 61,   fields: '291/305',     accuracy: '95.4%',  highlight: false },
  { category: 'Insurance Policies',     docs: 97,   fields: '727/763',     accuracy: '95.3%',  highlight: false },
  { category: 'Insurance Claims',       docs: 152,  fields: '944/1,020',   accuracy: '92.5%',  highlight: false },
  { category: 'Adversarial',           docs: 11,   fields: '55/60',       accuracy: '91.7%',  highlight: false },
  { category: 'Invoices',              docs: 107,  fields: '478/532',     accuracy: '89.8%',  highlight: false },
];

const competitors = [
  { name: 'Koji',         byo: '✓', selfHost: '✓', schemaSystem: 'Full type system',  corpus: '✓', hitl: '✓', trace: '✓', pricing: '$0 / $499 / Custom' },
  { name: 'FurtherAI',    byo: '—', selfHost: '—', schemaSystem: 'Opaque',            corpus: '—', hitl: '—', trace: '—', pricing: 'Enterprise only' },
  { name: 'LlamaCloud',   byo: '—', selfHost: '—', schemaSystem: 'Field list',        corpus: '—', hitl: '—', trace: '—', pricing: 'Opaque credits' },
  { name: 'Reducto',      byo: '—', selfHost: '—', schemaSystem: 'Field list',        corpus: '—', hitl: '—', trace: '—', pricing: 'Opaque credits' },
  { name: 'Unstructured', byo: '—', selfHost: 'Crippled', schemaSystem: 'No schema', corpus: '—', hitl: '—', trace: '—', pricing: 'Enterprise only' },
];

const insuranceBreakdown = [
  { sub: 'Demand Letters', docs: 30, accuracy: '96.7%', notes: 'Free-text with state-from-address derivation' },
  { sub: 'Certificates',  docs: 61, accuracy: '95.4%', notes: 'Certificates of liability' },
  { sub: 'Policies',     docs: 97,  accuracy: '95.3%', notes: 'Dec pages, endorsements, schedules' },
  { sub: 'Claims (filled)', docs: 50, accuracy: '93.6%', notes: 'ACORD-style claim forms' },
  { sub: 'Loss Runs',     docs: 50, accuracy: '90.8%', notes: 'Multi-page tabular, header carry-forward in dev' },
];

const subprocessors = [
  { name: 'Cloudflare', purpose: 'Infrastructure (Workers, Pages, Containers, R2)', location: 'Global' },
  { name: 'Neon',       purpose: 'Postgres database', location: 'Selectable' },
  { name: 'Clerk',      purpose: 'Authentication', location: 'US' },
  { name: 'Stripe',     purpose: 'Payment processing', location: 'US' },
];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Koji — Production-grade document extraction. Sales deck for enterprise buyers." />
  <meta name="robots" content="noindex" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
  <title>Koji — Sales Deck</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    rel="preload" as="style"
    href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300..900&family=Instrument+Sans:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
    onload="this.onload=null;this.rel='stylesheet'"
  />
  <noscript>
    <link rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300..900&family=Instrument+Sans:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
    />
  </noscript>
</head>
<body>
  <!-- Toolbar -->
  <div class="deck-toolbar no-print">
    <a href="/" class="back-link">
      <span class="arrow">←</span>
      <span>getkoji.dev</span>
    </a>
    <button type="button" class="print-btn" data-print>
      <span>Download PDF</span>
      <span class="arrow">↓</span>
    </button>
  </div>

  <!-- Personalization bar -->
  <div class="deck-personalize no-print">
    <div class="personalize-fields">
      <label>
        <span>Customer</span>
        <input type="text" id="cfg-customer" placeholder="Acme Insurance" />
      </label>
      <label>
        <span>Logo URL</span>
        <input type="text" id="cfg-logo" placeholder="https://..." />
      </label>
      <label>
        <span>Presenter</span>
        <input type="text" id="cfg-presenter" placeholder="Frank Thomas, Founder" />
      </label>
      <label>
        <span>Contact</span>
        <input type="text" id="cfg-contact" placeholder="sales@getkoji.dev" />
      </label>
    </div>
  </div>

  <main class="deck">

    <!-- ============================================ -->
    <!-- SLIDE 1: Title                               -->
    <!-- ============================================ -->
    <section class="slide slide-title">
      <div class="brand">
        <BrandMark size={42} />
        <span class="wordmark">koji</span>
      </div>
      <h1 class="title-headline">
        Production-grade<br/>document extraction.
      </h1>
      <p class="title-sub">Your models. Your infrastructure. Your data.</p>
      <div class="title-personalized">
        <div class="title-prepared" id="prepared-for" style="display:none">
          <span class="prepared-label">Prepared for</span>
          <span class="prepared-name" id="prepared-name"></span>
          <img id="prepared-logo" class="prepared-logo" style="display:none" alt="" />
        </div>
        <p class="title-presenter" id="presenter-line" style="display:none"></p>
      </div>
      <p class="title-url">getkoji.dev</p>
    </section>

    <!-- ============================================ -->
    <!-- SLIDE 2: The Problem                         -->
    <!-- ============================================ -->
    <section class="slide">
      <div class="slide-label"><span class="num">01</span> The Problem</div>
      <h2 class="slide-heading">"Just call an LLM" works for demos.<br/><em class="accent">It breaks in production.</em></h2>
      <div class="problem-grid">
        <div class="problem-item">
          <span class="problem-icon">✗</span>
          <div><strong>No validation</strong><br/>The model hallucinates enum values and fills blank fields with guesses</div>
        </div>
        <div class="problem-item">
          <span class="problem-icon">✗</span>
          <div><strong>No versioning</strong><br/>You change the prompt and can't tell if accuracy got better or worse</div>
        </div>
        <div class="problem-item">
          <span class="problem-icon">✗</span>
          <div><strong>No confidence scoring</strong><br/>Everything looks equally certain, even when it's wrong</div>
        </div>
        <div class="problem-item">
          <span class="problem-icon">✗</span>
          <div><strong>No review routing</strong><br/>Low-confidence results go straight to your database</div>
        </div>
        <div class="problem-item">
          <span class="problem-icon">✗</span>
          <div><strong>No audit trail</strong><br/>"What did we extract 3 months ago?" is unanswerable</div>
        </div>
      </div>
    </section>

    <!-- ============================================ -->
    <!-- SLIDE 3: What Koji Is                        -->
    <!-- ============================================ -->
    <section class="slide">
      <div class="slide-label"><span class="num">02</span> The Solution</div>
      <h2 class="slide-title">Koji is the production layer between<br/>your AI models and your structured data.</h2>
      <div class="pillars">
        <div class="pillar">
          <h3>Schema-first</h3>
          <p>Define what you want as versioned, validated YAML — not a prompt you tune by feel.</p>
        </div>
        <div class="pillar">
          <h3>BYO models</h3>
          <p>Run on your own OpenAI, Anthropic, Azure, Bedrock, or Ollama endpoint. We orchestrate; you own the inference.</p>
        </div>
        <div class="pillar">
          <h3>Self-hostable</h3>
          <p><code>docker compose up</code> on your infrastructure. Your data never leaves your network. Apache 2.0.</p>
        </div>
        <div class="pillar">
          <h3>Measurably accurate</h3>
          <p>Every schema has a corpus. Every change has a benchmark. Every regression is caught before it ships.</p>
        </div>
      </div>
    </section>

    <!-- ============================================ -->
    <!-- SLIDE 4: The Schema Advantage                -->
    <!-- ============================================ -->
    <section class="slide">
      <div class="slide-label"><span class="num">03</span> The Schema Advantage</div>
      <h2 class="slide-heading" style="white-space:nowrap">Not field lists. <em class="accent">A type system for extraction.</em></h2>
      <div class="schema-split">
        <div class="schema-code">
          <pre><code>description_of_loss:
  type: string
  nullable: true
  importance: high
  review_below: 0.85
  extraction_guidance: |
    Extract from the narrative section.
    NOT a classification code.
  validate:
    min_words: 20
    on_fail: null

state:
  derived_from: address
  method: us_state_lookup

form_type:
  type: enum
  values: [Loss Run, Demand Letter]
  validate:
    on_miss: snap_closest</code></pre>
        </div>
        <div class="schema-features">
          <div class="schema-feat"><strong>Types & validation</strong> — min/max, regex, enum snapping, word count</div>
          <div class="schema-feat"><strong>Normalization</strong> — dates to ISO 8601, currency to minor units, locale-aware parsing</div>
          <div class="schema-feat"><strong>Derived fields</strong> — state from address, first/last/sum from arrays</div>
          <div class="schema-feat"><strong>Extraction guidance</strong> — per-field prompt hints for the model</div>
          <div class="schema-feat"><strong>Confidence thresholds</strong> — per-field HITL routing: below 0.85 → human review</div>
          <div class="schema-feat"><strong>Merge strategies</strong> — per-field rules for combining multi-chunk results</div>
          <p class="schema-note">No competitor offers this level of configurability.</p>
        </div>
      </div>
    </section>

    <!-- ============================================ -->
    <!-- SLIDE 5: Pipeline                            -->
    <!-- ============================================ -->
    <section class="slide">
      <div class="slide-label"><span class="num">04</span> The Pipeline</div>
      <h2 class="slide-title">Eight stages. Each one traces. Each one retries independently.</h2>
      <div class="pipeline-flow">
        <div class="stage">Preflight</div>
        <span class="arrow-right">→</span>
        <div class="stage">OCR</div>
        <span class="arrow-right">→</span>
        <div class="stage">Chunk</div>
        <span class="arrow-right">→</span>
        <div class="stage">Route</div>
        <span class="arrow-right">→</span>
        <div class="stage stage-extract">Extract</div>
        <span class="arrow-right">→</span>
        <div class="stage">Merge</div>
        <span class="arrow-right">→</span>
        <div class="stage">Score</div>
        <span class="arrow-right">→</span>
        <div class="stage">Validate</div>
      </div>
      <div class="pipeline-detail">
        <div class="detail-item"><strong>Preflight</strong> — MIME check, size, dedup, OCR detection</div>
        <div class="detail-item"><strong>OCR</strong> — native text or vision bypass for thermal/scanned</div>
        <div class="detail-item"><strong>Chunk</strong> — semantic, page, overlap, row-based, with header carry-forward</div>
        <div class="detail-item"><strong>Route</strong> — pick the right model per chunk, fallback chains</div>
        <div class="detail-item"><strong>Extract</strong> — structured output via your BYO endpoint</div>
        <div class="detail-item"><strong>Merge</strong> — combine chunks with conflict detection</div>
        <div class="detail-item"><strong>Score</strong> — per-field confidence from model logprobs + agreement signals</div>
        <div class="detail-item"><strong>Validate</strong> — schema rules enforced, soft violations lower confidence</div>
      </div>
    </section>

    <!-- ============================================ -->
    <!-- SLIDE 6: BYO Pricing                         -->
    <!-- ============================================ -->
    <section class="slide">
      <div class="slide-label"><span class="num">05</span> BYO Inference</div>
      <h2 class="slide-title">You pay your models, not us.<br/><em class="accent">We never touch the inference bill.</em></h2>
      <div class="byo-split">
        <div class="byo-col">
          <h3 class="byo-heading">What you pay Koji</h3>
          <p>Platform subscription ($499/mo Scale)</p>
          <p>Per-document overage ($0.08/doc above 5,000/mo)</p>
          <p class="byo-emphasis">Transparent. Predictable. Two line items.</p>
        </div>
        <div class="byo-col">
          <h3 class="byo-heading">What you pay your AI vendor</h3>
          <p>Your contracted rate — OpenAI, Anthropic, Azure, Bedrock, Ollama</p>
          <p>Your existing cloud commitment, unchanged</p>
          <p class="byo-emphasis">Your relationship. Your negotiated pricing.</p>
        </div>
      </div>
    </section>

    <!-- ============================================ -->
    <!-- SLIDE 7: Benchmarks                          -->
    <!-- ============================================ -->
    <section class="slide">
      <div class="slide-label"><span class="num">06</span> Accuracy</div>
      <h2 class="slide-heading">552 documents. 3,257 fields. 5 domains.<br/><em class="accent">Six categories above 95%. All above 89%.</em></h2>
      <table class="bench-table" style="margin-top:-2rem">
        <thead>
          <tr><th>Category</th><th>Docs</th><th>Fields</th><th>Accuracy</th></tr>
        </thead>
        <tbody>
          {benchmarks.map(b => (
            <tr class={b.highlight ? 'highlight' : ''}>
              <td>{b.category}</td>
              <td class="mono">{b.docs}</td>
              <td class="mono">{b.fields}</td>
              <td class="mono accuracy">{b.accuracy}</td>
            </tr>
          ))}
          <tr class="total-row">
            <td><strong>Total</strong></td>
            <td class="mono"><strong>552</strong></td>
            <td class="mono"><strong>3,072/3,257</strong></td>
            <td class="mono accuracy"><strong>94.3%</strong></td>
          </tr>
        </tbody>
      </table>
      <p class="bench-note">Held-out documents + adversarial cases. Full corpus available for independent benchmarking.</p>
    </section>

    <!-- ============================================ -->
    <!-- SLIDE 8: Quality Loop                        -->
    <!-- ============================================ -->
    <section class="slide">
      <div class="slide-label"><span class="num">07</span> The Quality Loop</div>
      <h2 class="slide-title">Accuracy isn't a number.<br/><em class="accent">It's a system.</em></h2>
      <div class="loop-diagram">
        <div class="loop-step">Define Schema</div>
        <span class="loop-arrow">→</span>
        <div class="loop-step">Build Corpus</div>
        <span class="loop-arrow">→</span>
        <div class="loop-step">Run Validate</div>
        <span class="loop-arrow">→</span>
        <div class="loop-step">See Regressions</div>
        <span class="loop-arrow">→</span>
        <div class="loop-step">Fix & Rebench</div>
        <span class="loop-arrow loop-return">↩</span>
      </div>
      <div class="loop-features">
        <div class="loop-feat"><strong>Corpus</strong> — ground-truth documents scored against your schema. Grows from production.</div>
        <div class="loop-feat"><strong>Validate</strong> — every schema change runs against the corpus. Per-field regressions visible.</div>
        <div class="loop-feat"><strong>Benchmark</strong> — compare models head-to-head on your corpus. Cost vs accuracy.</div>
        <div class="loop-feat"><strong>Deploy gate</strong> — regressing schemas cannot deploy. CI-enforceable.</div>
      </div>
    </section>

    <!-- ============================================ -->
    <!-- SLIDE 9: Trace View                          -->
    <!-- ============================================ -->
    <section class="slide">
      <div class="slide-label"><span class="num">08</span> Trace View</div>
      <h2 class="slide-title">Every document gets a full trace.</h2>
      <div class="trace-features">
        <div class="trace-feat">Waterfall timeline of every pipeline stage with duration and cost</div>
        <div class="trace-feat">Per-field confidence scores with threshold markers</div>
        <div class="trace-feat">Exact model input and output at each stage</div>
        <div class="trace-feat">HITL routing decision — why it went to review, or didn't</div>
        <div class="trace-feat">Error details with classification: our fault vs your data vs provider</div>
        <div class="trace-feat">Paste a document ID, see what happened in 5 seconds</div>
      </div>
      <p class="trace-note">When a customer calls and says "this extraction is wrong," you paste the ID and see exactly what happened.</p>
    </section>

    <!-- ============================================ -->
    <!-- SLIDE 10: Security                           -->
    <!-- ============================================ -->
    <section class="slide">
      <div class="slide-label"><span class="num">09</span> Security & Compliance</div>
      <h2 class="slide-title">Honest about what's certified.<br/><em class="accent">Clear about what's next.</em></h2>
      <div class="compliance-grid">
        <div class="compliance-item done"><span class="check">✓</span> TLS 1.2+ in transit</div>
        <div class="compliance-item done"><span class="check">✓</span> Encryption at rest</div>
        <div class="compliance-item done"><span class="check">✓</span> Postgres Row-Level Security</div>
        <div class="compliance-item done"><span class="check">✓</span> RBAC with 7 roles</div>
        <div class="compliance-item done"><span class="check">✓</span> Audit log (up to 7yr retention)</div>
        <div class="compliance-item done"><span class="check">✓</span> Self-hostable (your VPC)</div>
        <div class="compliance-item done"><span class="check">✓</span> BYO model endpoints</div>
        <div class="compliance-item done"><span class="check">✓</span> DPA available</div>
        <div class="compliance-item planned"><span class="clock">◐</span> SOC 2 Type 1 — Q4 2026</div>
        <div class="compliance-item planned"><span class="clock">◐</span> SOC 2 Type 2 — 2027</div>
        <div class="compliance-item done"><span class="check">✓</span> SSO / SAML (Enterprise)</div>
        <div class="compliance-item planned"><span class="clock">◐</span> HIPAA BAA — on request</div>
      </div>
      <p class="compliance-note">Full posture: getkoji.dev/compliance</p>
    </section>

    <!-- ============================================ -->
    <!-- SLIDE 11: Deployment                         -->
    <!-- ============================================ -->
    <section class="slide">
      <div class="slide-label"><span class="num">10</span> Deployment</div>
      <h2 class="slide-title">Same code, three runtimes.</h2>
      <div class="deploy-options">
        <div class="deploy-opt">
          <h3>Koji Cloud</h3>
          <p>We host it. You configure your schema, connect your endpoint, process documents. Zero ops burden.</p>
        </div>
        <div class="deploy-opt">
          <h3>Self-Hosted</h3>
          <p><code>docker compose up</code> with bundled Postgres. Same product, same dashboard. Your data stays in your network. Apache 2.0.</p>
        </div>
        <div class="deploy-opt">
          <h3>Enterprise Managed</h3>
          <p>We help you deploy in your cloud or on-prem. Helm chart, dedicated support, custom SLA, compliance artifacts.</p>
        </div>
      </div>
    </section>

    <!-- ============================================ -->
    <!-- SLIDE 12: Pricing                            -->
    <!-- ============================================ -->
    <section class="slide">
      <div class="slide-label"><span class="num">11</span> Pricing</div>
      <h2 class="slide-title">Simple pricing. <em class="accent">No surprises.</em></h2>
      <table class="pricing-table">
        <thead>
          <tr><th></th><th>Free</th><th>Scale</th><th>Enterprise</th></tr>
        </thead>
        <tbody>
          <tr><td>Price</td><td class="mono">$0</td><td class="mono"><strong>$499/mo</strong></td><td class="mono">Custom</td></tr>
          <tr><td>Documents/mo</td><td class="mono">500</td><td class="mono">5,000</td><td class="mono">Negotiated</td></tr>
          <tr><td>Overage</td><td class="mono">—</td><td class="mono">$0.08/doc</td><td class="mono">Negotiated</td></tr>
          <tr><td>Pages/doc</td><td class="mono">100</td><td class="mono">100</td><td class="mono">Unlimited</td></tr>
          <tr><td>HITL Review</td><td>—</td><td>✓</td><td>✓</td></tr>
          <tr><td>Benchmarks</td><td>—</td><td>✓</td><td>✓</td></tr>
          <tr><td>SSO / SAML</td><td>—</td><td>—</td><td>✓</td></tr>
          <tr><td>Support</td><td>Community</td><td>Priority 4h</td><td>Dedicated</td></tr>
        </tbody>
      </table>
      <p class="pricing-note">BYO inference on all tiers. Self-hosted gets the Scale feature set for free.</p>
    </section>

    <!-- ============================================ -->
    <!-- SLIDE 13: Next Steps                         -->
    <!-- ============================================ -->
    <section class="slide slide-cta">
      <div class="slide-label"><span class="num">12</span> Next Steps</div>
      <h2 class="slide-title">Start with your hardest document type.<br/><em class="accent">Prove it works there first.</em></h2>
      <div class="next-steps">
        <div class="step">
          <span class="step-num">1</span>
          <div><strong>Pilot.</strong> 30-day paid pilot. We define success criteria together. Hit them → contract converts. Miss them → walk away.</div>
        </div>
        <div class="step">
          <span class="step-num">2</span>
          <div><strong>Your documents.</strong> Run our benchmark suite against your actual corpus. See the numbers before you commit.</div>
        </div>
        <div class="step">
          <span class="step-num">3</span>
          <div><strong>Your infrastructure.</strong> Deploy on your infra or spin up a hosted tenant — your choice.</div>
        </div>
      </div>
      <p class="contact" id="contact-line">sales@getkoji.dev</p>
    </section>

    <!-- ============================================ -->
    <!-- APPENDIX                                     -->
    <!-- ============================================ -->
    <div class="appendix-divider">
      <span>Appendix — Technical Deep-Dive</span>
    </div>

    <!-- A1: Competitor Matrix -->
    <section class="slide slide-appendix">
      <div class="slide-label"><span class="num">A1</span> Competitor Comparison</div>
      <table class="comp-table">
        <thead>
          <tr><th></th><th>BYO</th><th>Self-Host</th><th>Schema</th><th>Corpus</th><th>HITL</th><th>Trace</th><th>Entry Price</th></tr>
        </thead>
        <tbody>
          {competitors.map(c => (
            <tr class={c.name === 'Koji' ? 'koji-row' : ''}>
              <td><strong>{c.name}</strong></td>
              <td>{c.byo}</td>
              <td>{c.selfHost}</td>
              <td>{c.schemaSystem}</td>
              <td>{c.corpus}</td>
              <td>{c.hitl}</td>
              <td>{c.trace}</td>
              <td class="mono">{c.pricing}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </section>

    <!-- A2: Insurance Breakdown -->
    <section class="slide slide-appendix">
      <div class="slide-label"><span class="num">A2</span> Insurance-Specific Accuracy</div>
      <table class="bench-table">
        <thead>
          <tr><th>Sub-category</th><th>Docs</th><th>Accuracy</th><th>Notes</th></tr>
        </thead>
        <tbody>
          {insuranceBreakdown.map(b => (
            <tr>
              <td>{b.sub}</td>
              <td class="mono">{b.docs}</td>
              <td class="mono accuracy">{b.accuracy}</td>
              <td class="notes">{b.notes}</td>
            </tr>
          ))}
        </tbody>
      </table>
      <p class="bench-note">288 insurance documents across 5 sub-categories. 93.2% overall. Improving weekly.</p>
    </section>

    <!-- A3: Billing Credits -->
    <section class="slide slide-appendix">
      <div class="slide-label"><span class="num">A3</span> Billing — Credits for Our Bugs</div>
      <div class="credits-list">
        <div class="credit-item credit-good"><strong>Successful extraction</strong> → billed</div>
        <div class="credit-item credit-refund"><strong>Koji infrastructure failure</strong> → automatic credit (you don't pay for our bugs)</div>
        <div class="credit-item credit-good"><strong>Your schema / input issue</strong> → billed (disputable on request)</div>
        <div class="credit-item credit-neutral"><strong>Preflight rejection</strong> → not billed (no work done)</div>
        <div class="credit-item credit-neutral"><strong>Deduped document</strong> → not billed (cached result)</div>
      </div>
      <p class="bench-note">Your invoice shows billed + credited separately. The credit line is always visible, even when zero.</p>
    </section>

