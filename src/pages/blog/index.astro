---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout
  title="Blog — Koji"
  description="Engineering blog from the Koji team. Deep dives on document extraction, benchmarking, schema design, and building in the open."
>
  <Header />
  <main class="blog-index">
    <div class="container">
      <header class="blog-header">
        <span class="section-label">Blog</span>
        <h1>Engineering blog</h1>
        <p class="blog-description">
          How we build Koji — extraction pipelines, benchmarking methodology,
          schema design, and lessons from running document AI in production.
        </p>
      </header>

      {posts.length === 0 && (
        <p class="empty">No posts yet. Check back soon.</p>
      )}

      <ul class="post-list">
        {posts.map((post) => (
          <li>
            <a href={`/blog/${post.id}`} class="post-card">
              <div class="post-meta">
                <time datetime={post.data.date.toISOString()}>
                  {post.data.date.toLocaleDateString('en-US', {
                    year: 'numeric',
                    month: 'long',
                    day: 'numeric',
                  })}
                </time>
                {post.data.tags.length > 0 && (
                  <>
                    <span class="meta-sep">/</span>
                    {post.data.tags.map((tag: string) => (
                      <span class="tag">{tag}</span>
                    ))}
                  </>
                )}
              </div>
              <h2>{post.data.title}</h2>
              <p>{post.data.description}</p>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </main>
  <Footer />
</Layout>

<style>
  .blog-index {
    padding-top: 10rem;
    padding-bottom: 6rem;
  }

  .blog-index .container {
    max-width: 720px;
  }

  .blog-header {
    margin-bottom: 4rem;
  }

  .section-label {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--vermillion);
    margin-bottom: 1.25rem;
  }

  h1 {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 5vw, 3.2rem);
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: -0.025em;
    margin: 0 0 1.25rem;
  }

  .blog-description {
    font-size: 1.1rem;
    line-height: 1.6;
    color: var(--ink-2);
    max-width: 560px;
  }

  .empty {
    color: var(--ink-3);
    font-size: 1rem;
  }

  .post-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .post-card {
    display: block;
    padding: 2.25rem 0;
    border-top: 1px solid var(--border);
    transition: background 0.3s;
  }

  .post-list li:last-child .post-card {
    border-bottom: 1px solid var(--border);
  }

  .post-card:hover {
    background: var(--cream-2);
    margin: 0 -1.5rem;
    padding-left: 1.5rem;
    padding-right: 1.5rem;
    border-radius: 4px;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--ink-3);
    letter-spacing: 0.02em;
    margin-bottom: 0.75rem;
  }

  .meta-sep {
    opacity: 0.4;
  }

  .tag {
    color: var(--vermillion);
  }

  .post-card h2 {
    font-family: var(--font-display);
    font-size: 1.45rem;
    font-weight: 420;
    line-height: 1.25;
    letter-spacing: -0.01em;
    margin: 0 0 0.6rem;
    color: var(--ink);
    transition: color 0.3s;
  }

  .post-card:hover h2 {
    color: var(--vermillion);
  }

  .post-card p {
    font-size: 0.95rem;
    line-height: 1.55;
    color: var(--ink-2);
    max-width: 560px;
  }
</style>
